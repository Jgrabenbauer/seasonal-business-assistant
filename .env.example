# Database
DATABASE_URL="postgresql://sba:sba_dev@localhost:5432/sba_dev"
# Optional direct connection for Prisma CLI when DATABASE_URL uses a pooler
# DIRECT_URL="postgresql://sba:sba_dev@localhost:5432/sba_dev"

# Auth
SESSION_SECRET="replace-with-a-32-char-secret"
MAGIC_LINK_SECRET="replace-with-a-32-char-secret"

# App
PUBLIC_BASE_URL="http://localhost:5173"
NODE_ENV="development"

# SMS (default: console — no setup needed)
SMS_PROVIDER="console"
# SMS_PROVIDER="twilio"
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# Storage (default: local — no setup needed)
STORAGE_PROVIDER="local"
# STORAGE_PROVIDER="s3"
# AWS_REGION=""
# S3_BUCKET=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
